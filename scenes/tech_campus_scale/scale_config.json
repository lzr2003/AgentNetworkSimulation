  "network_generation_rules": [
    {
      "sub_id": "sub_dev_collab",
      "topology_type": "MESH",
      "description": "开发团队内部协作平面",
      "generation_rule": "INTRA_CATEGORY_FULL_INTER_CATEGORY_SPARSE",
      "source_categories": ["software_dev", "hardware_dev", "ai_researcher", "architect", "product_manager", "tech_writer", "qa_engineer", "devops_engineer"],
      "target_categories": ["software_dev", "hardware_dev", "ai_researcher", "architect", "product_manager", "tech_writer", "qa_engineer", "devops_engineer"],
      "paradigm": "COLLABORATION",
      "edge_density": { "intra": 0.00005, "inter": 0.00001 },
      "max_total_edges": 20000000,
      "channel_prefix": "vlan_collab"
    },
    {
      "sub_id": "sub_repo_ci",
      "topology_type": "STAR",
      "description": "代码仓库/CI/CD中心：repo_admin和devops为Hub",
      "generation_rule": "STAR_HUB",
      "hub_categories": ["repo_admin", "devops_engineer"],
      "spoke_categories": ["software_dev", "hardware_dev", "ai_researcher", "architect", "product_manager", "tech_writer", "qa_engineer"],
      "paradigm": "COLLABORATION",
      "edge_density": { "hub_to_spoke": 0.002 },
      "max_total_edges": 2000000,
      "channel_prefix": "vlan_repo"
    },
    {
      "sub_id": "sub_qa_notify",
      "topology_type": "BIPARTITE",
      "description": "测试反馈闭环：QA/架构师 → 开发组",
      "generation_rule": "BIPARTITE",
      "source_categories": ["qa_engineer", "architect"],
      "target_categories": ["software_dev", "hardware_dev", "ai_researcher"],
      "paradigm": "COLLABORATION",
      "edge_density": { "inter": 0.00003 },
      "max_total_edges": 5000000,
      "channel_prefix": "vlan_qa"
    },
    {
      "sub_id": "sub_mgmt_plane",
      "topology_type": "STAR",
      "description": "管理层协调平面：产品经理和架构师为Hub",
      "generation_rule": "STAR_HUB",
      "hub_categories": ["product_manager", "architect"],
      "spoke_categories": ["software_dev", "hardware_dev", "ai_researcher", "tech_writer", "qa_engineer", "devops_engineer", "repo_admin"],
      "paradigm": "COLLABORATION",
      "edge_density": { "hub_to_spoke": 0.0005 },
      "max_total_edges": 10000000,
      "channel_prefix": "vlan_mgmt"
    }
  ],

  "network_global_constraints": {
    "max_total_edges_across_all_subnets": 50000000,
    "max_edges_per_agent_global": 300,
    "oversubscription_ratio": { "repo_admin": 200, "architect": 80, "qa_engineer": 35, "devops_engineer": 40, "software_dev": 25, "hardware_dev": 15, "ai_researcher": 12, "product_manager": 30, "tech_writer": 20 },
    "bandwidth_limits_gbps": {
      "EAST_WEST":   { "per_agent_avg_mbps": 1,    "total_aggregate_gbps": 1000 },
      "NORTH_SOUTH": { "per_agent_avg_mbps": 10,   "total_aggregate_gbps": 5000 },
      "INTERNAL":    { "per_agent_avg_mbps": 100,  "total_aggregate_gbps": 50000 }
    }
  },

  "traffic_generation_rules": {
    "EAST_WEST": {
      "description": "Agent间东西向协作流量（CR通知/评审/测试报告）",
      "generated_by": ["notify_team", "review_document", "run_test"],
      "avg_requests_per_agent_per_round": 0.3,
      "size_distribution": { "min_kb": 1, "p50_kb": 4, "p95_kb": 32, "max_kb": 256 }
    },
    "NORTH_SOUTH": {
      "description": "外部API调用南北向流量（LLM推理/EDA仿真/Cloud Build）",
      "generated_by": ["request_external_api"],
      "avg_requests_per_agent_per_round": 0.05,
      "size_distribution": { "min_kb": 4, "p50_kb": 500, "p95_kb": 512000, "max_kb": 5242880 },
      "rate_limit_per_round_global": 50000,
      "external_endpoints": {
        "LLM_INFERENCE": { "share": 0.60, "avg_latency_ms": 200 },
        "EDA_CLOUD":     { "share": 0.15, "avg_latency_ms": 5000 },
        "CLOUD_BUILD":   { "share": 0.25, "avg_latency_ms": 300 }
      }
    },
    "INTERNAL": {
      "description": "内部基础设施流量（Git push/CI build/Registry镜像/模型存储）",
      "generated_by": ["submit_code", "submit_model", "submit_design", "write_document", "handle_push", "trigger_ci_cd"],
      "avg_requests_per_agent_per_round": 0.6,
      "size_distribution": { "min_kb": 1, "p50_kb": 1024, "p95_kb": 524288, "max_kb": 5242880 }
    }
  },

  "mapping_rules": {
    "_description": "agent_categories → network subnets 映射，定义每个类别在各子网中的角色",
    "rules": [
      { "category_id": "software_dev",    "subnets": ["sub_dev_collab","sub_repo_ci","sub_qa_notify","sub_mgmt_plane"], "roles": ["peer","spoke","target","spoke"] },
      { "category_id": "hardware_dev",    "subnets": ["sub_dev_collab","sub_repo_ci","sub_qa_notify","sub_mgmt_plane"], "roles": ["peer","spoke","target","spoke"] },
      { "category_id": "ai_researcher",   "subnets": ["sub_dev_collab","sub_repo_ci","sub_qa_notify","sub_mgmt_plane"], "roles": ["peer","spoke","target","spoke"] },
      { "category_id": "architect",       "subnets": ["sub_dev_collab","sub_repo_ci","sub_qa_notify","sub_mgmt_plane"], "roles": ["peer","spoke","source","hub"] },
      { "category_id": "product_manager", "subnets": ["sub_dev_collab","sub_repo_ci","sub_mgmt_plane"],               "roles": ["peer","spoke","hub"] },
      { "category_id": "tech_writer",     "subnets": ["sub_dev_collab","sub_repo_ci","sub_mgmt_plane"],               "roles": ["peer","spoke","spoke"] },
      { "category_id": "qa_engineer",     "subnets": ["sub_dev_collab","sub_repo_ci","sub_qa_notify","sub_mgmt_plane"], "roles": ["peer","spoke","source","spoke"] },
      { "category_id": "devops_engineer", "subnets": ["sub_dev_collab","sub_repo_ci","sub_mgmt_plane"],               "roles": ["peer","hub","spoke"] },
      { "category_id": "repo_admin",      "subnets": ["sub_repo_ci","sub_mgmt_plane"],                               "roles": ["hub","spoke"] }
    ]
  },

  "scaling_parameters": {
    "_description": "全局缩放参数，修改 scale_factor 或 total_agents_target 可线性调整规模",
    "total_agents_target": 1000000,
    "llm_enabled_agents_ratio": 0.015,
    "llm_enabled_agents_estimate": 15000,
    "scale_factors": {
      "agent_count":        { "min": 100000, "default": 575000, "max": 5000000 },
      "edges_per_subnet":   { "formula": "min(agents * avg_peers * density / 2, max_total_edges)" },
      "traffic_throughput": { "formula": "agents * avg_requests_per_round * avg_payload / round_duration" }
    }
  }
}
