      "docker_image": "python:3.10-slim",
      "pip_packages": [
        "requests==2.31.0"
      ],
      "skill_bindings": [
        {
          "skill_name": "move_and_reconnaissance",
          "endpoint": "http://simulation-env/api/skills/recon",
          "description": "探雷兵执行移动与探雷。接收当前的 current_round 确保时序同步。踩雷不死，仅返回雷区情报。"
