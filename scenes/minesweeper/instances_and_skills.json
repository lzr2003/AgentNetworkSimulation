{
  "container_instances": {
    "CMDR_01": {
      "runtime_engine": "docker",
      "docker_image": "python:3.10-slim",
      "pip_packages": [
        "numpy==1.24.3",
        "requests==2.31.0"
      ],
      "skill_bindings": [
        {
          "skill_name": "initialize_minesweeper_map",
          "endpoint": "http://simulation-env/api/skills/init_map",
          "description": "仅限指挥官 CMDR_01 在第 0 轮初始化调用，生成 9x9 棋盘及 10 个地雷。"
        },
        {
          "skill_name": "query_game_status",
          "endpoint": "http://simulation-env/api/skills/status",
          "description": "全局状态审计：查询当前 9x9 地图的整体覆盖率、累计发现的地雷以及全局 Round 进度。"
        }
      ]
    },
