FROM node:22-slim

# Debian 国内镜像加速
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || true

# Python for the agent server wrapper
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-requests \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (npm 国内镜像)
RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Python dependencies for the agent server
RUN pip install --no-cache-dir --break-system-packages -i https://mirrors.aliyun.com/pypi/simple/ fastapi uvicorn pydantic httpx requests

COPY agent_server_claude.py /app/
COPY agent_network/ /app/agent_network/

# 注意: 使用 docker-compose 部署时，通过 environment 覆盖为 service name:
#   MESSAGE_BUS_URL=http://message-bus:9000
#   SERVER_URL=http://server:8000
# host.docker.internal 仅在 Docker Desktop (Windows/Mac) 上可用，
# Linux 请使用 docker-compose 或 --add-host 参数
ENV AGENT_ID="agent-001"
ENV AGENT_ROLE="generic"
ENV AGENT_NAME="Agent"
ENV MESSAGE_BUS_URL="http://localhost:9000"
ENV SERVER_URL="http://localhost:8000"

EXPOSE 8000

CMD ["python3", "agent_server_claude.py"]
